# Shared secret - must match server/.env's AI_SERVICE_API_KEY
INTERNAL_API_KEY=

# Google Gemini (free tier) - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Qdrant (docker-compose up -d qdrant, from the server/ directory)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Cloudflare R2 (S3-compatible) - dashboard.cloudflare.com -> R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=repository-archives

REPO_CACHE_DIR=./repo-cache
