# Base URL of the EngineerBrain Express API (including the /api/v1 prefix).
ENGINEERBRAIN_API_URL=http://localhost:4000/api/v1

# Which transport to start with: "stdio" (default, for Claude Desktop/Code/Cursor
# local configs) or "http" (Streamable HTTP, for a centrally-hosted server).
MCP_TRANSPORT=stdio

# Required for stdio - one API key, created from an organization's Settings page,
# scoping this server process to that single organization. Not used in http mode,
# where each request supplies its own bearer token via the Authorization header.
ENGINEERBRAIN_API_KEY=

# Only used when MCP_TRANSPORT=http.
MCP_HTTP_PORT=3800
