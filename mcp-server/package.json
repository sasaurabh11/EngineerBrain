{
  "name": "@engineerbrain/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing EngineerBrain's engineering intelligence platform to MCP-compatible AI clients",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "engineerbrain-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
