NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Clerk (from https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173

# RabbitMQ (docker-compose up -d for local dev)
RABBITMQ_URL=amqp://engineerbrain:engineerbrain@localhost:5672

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# AI service (FastAPI) - internal only, shared secret must match ai-service/.env's INTERNAL_API_KEY
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=

# Production Intelligence: encrypts ProductionIntegration credentials at rest.
# Generate with: openssl rand -base64 32
PRODUCTION_SECRET_KEY=
