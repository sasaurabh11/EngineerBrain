generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  DEVELOPER
  QA
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  DECLINED
}

enum GitHubAccountType {
  USER
  ORGANIZATION
}

enum InstallationStatus {
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

enum RepositoryVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum SyncTrigger {
  MANUAL
  WEBHOOK
  SCHEDULED
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
}

enum IssueState {
  OPEN
  CLOSED
}

enum IndexStatus {
  PENDING
  INDEXING
  INDEXED
  FAILED
}

enum SymbolKind {
  MODULE
  CLASS
  INTERFACE
  FUNCTION
  METHOD
}

enum ChunkKind {
  MODULE
  CLASS
  INTERFACE
  FUNCTION
  METHOD
  DOCUMENTATION
}

enum EmbeddingStatus {
  PENDING
  EMBEDDED
  FAILED
}

enum GraphEdgeType {
  IMPORTS
  CALLS
  EXTENDS
  IMPLEMENTS
  USES
  DEPENDS_ON_PACKAGE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum AiProvider {
  GEMINI
  GROQ
}

model User {
  id           String   @id @default(uuid())
  clerkId      String   @unique
  name         String
  email        String   @unique
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // AI provider preference: which LLM backs chat/task-engine/analysis for this
  // user. The encrypted*Key columns hold an optional personal API key
  // (envelope-encrypted via infra/crypto/secretBox.ts) - when set for the
  // selected provider, it's used instead of the app's shared default key.
  aiProvider         AiProvider @default(GEMINI)
  encryptedGeminiKey String?
  encryptedGroqKey   String?

  memberships            OrganizationMember[]
  ownedOrgs              Organization[]       @relation("OrganizationOwner")
  sentInvites            Invitation[]         @relation("InvitationInviter")
  connectedInstallations GitHubInstallation[] @relation("InstallationConnectedBy")
  importedRepositories   Repository[]         @relation("RepositoryImportedBy")
  conversations          Conversation[]
  createdApiKeys         ApiKey[]

  @@map("users")
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  logoUrl     String?
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner              User                 @relation("OrganizationOwner", fields: [ownerId], references: [id])
  members            OrganizationMember[]
  invitations        Invitation[]
  githubInstallation GitHubInstallation?
  repositories       Repository[]
  conversations      Conversation[]
  tasks              Task[]
  apiKeys            ApiKey[]

  productionIntegrations ProductionIntegration[]
  services               Service[]
  deployments            Deployment[]
  productionEvents       ProductionEvent[]
  incidents              Incident[]
  postmortems            Postmortem[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_members")
}

model Invitation {
  id             String           @id @default(uuid())
  email          String
  organizationId String
  role           OrgRole
  invitedById    String
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitationInviter", fields: [invitedById], references: [id])

  @@unique([email, organizationId])
  @@map("invitations")
}

// Org-scoped bearer credential for non-interactive clients (MCP server, CI,
// scripts) that can't do an interactive Clerk sign-in. Resolves to the same
// {userId, organizationId} shape requireOrgRole already expects, so every
// existing route's authorization logic runs unchanged - see auth.middleware.ts
// and rbac.middleware.ts.
model ApiKey {
  id             String    @id @default(uuid())
  organizationId String
  createdById    String
  name           String
  keyPrefix      String
  hashedKey      String    @unique
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId])
  @@map("api_keys")
}

model GitHubInstallation {
  id                   String             @id @default(uuid())
  organizationId       String             @unique
  githubInstallationId BigInt             @unique
  githubAccountLogin   String
  githubAccountId      BigInt
  githubAccountType    GitHubAccountType
  status               InstallationStatus @default(ACTIVE)
  connectedById        String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  connectedBy  User         @relation("InstallationConnectedBy", fields: [connectedById], references: [id])
  repositories Repository[]

  @@map("github_installations")
}

model Repository {
  id              String               @id @default(uuid())
  organizationId  String
  installationId  String
  githubRepoId    BigInt
  name            String
  fullName        String
  ownerLogin      String
  description     String?
  visibility      RepositoryVisibility
  defaultBranch   String
  primaryLanguage String?
  topics          String[]
  cloneUrl        String
  htmlUrl         String
  starsCount      Int
  forksCount      Int
  openIssuesCount Int
  sizeKb          Int
  githubPushedAt  DateTime?
  githubCreatedAt DateTime
  githubUpdatedAt DateTime
  syncStatus      SyncStatus           @default(PENDING)
  lastSyncedAt    DateTime?
  importedById    String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  installation GitHubInstallation @relation(fields: [installationId], references: [id])
  importedBy   User               @relation("RepositoryImportedBy", fields: [importedById], references: [id])
  branches     Branch[]
  commits      Commit[]
  contributors Contributor[]
  pullRequests PullRequest[]
  issues       Issue[]
  syncs        RepositorySync[]

  repositoryIndex RepositoryIndex?
  indexingJobs    IndexingJob[]
  files           RepositoryFile[]
  symbols         CodeSymbol[]
  chunks          Chunk[]
  graphEdges      CodeGraphEdge[]
  apiEndpoints    ApiEndpoint[]
  conversations   Conversation[]
  citations       Citation[]
  analyses        RepositoryAnalysis[]
  tasks           Task[]
  services        Service[]
  deployments     Deployment[]

  @@unique([organizationId, githubRepoId])
  @@map("repositories")
}

model Branch {
  id            String    @id @default(uuid())
  repositoryId  String
  name          String
  isProtected   Boolean   @default(false)
  lastCommitSha String
  lastCommitAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
  @@map("branches")
}

model Commit {
  id                String   @id @default(uuid())
  repositoryId      String
  sha               String
  message           String
  authorName        String
  authorEmail       String
  authorGithubLogin String?
  committedAt       DateTime
  htmlUrl           String
  createdAt         DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@map("commits")
}

model Contributor {
  id            String   @id @default(uuid())
  repositoryId  String
  githubUserId  BigInt
  githubLogin   String
  avatarUrl     String?
  contributions Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, githubUserId])
  @@map("contributors")
}

model PullRequest {
  id              String           @id @default(uuid())
  repositoryId    String
  githubId        BigInt
  number          Int
  title           String
  state           PullRequestState
  authorLogin     String
  isDraft         Boolean          @default(false)
  sourceBranch    String
  targetBranch    String
  htmlUrl         String
  githubCreatedAt DateTime
  githubUpdatedAt DateTime
  mergedAt        DateTime?
  closedAt        DateTime?

  repository  Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  @@unique([repositoryId, number])
  @@map("pull_requests")
}

model Issue {
  id              String     @id @default(uuid())
  repositoryId    String
  githubId        BigInt
  number          Int
  title           String
  state           IssueState
  authorLogin     String
  labels          String[]
  htmlUrl         String
  githubCreatedAt DateTime
  githubUpdatedAt DateTime
  closedAt        DateTime?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, number])
  @@map("issues")
}

model RepositorySync {
  id            String        @id @default(uuid())
  repositoryId  String
  trigger       SyncTrigger
  triggeredById String?
  status        SyncJobStatus
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  errorMessage  String?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("repository_syncs")
}

model WebhookEvent {
  id               String             @id @default(uuid())
  installationId   String?
  githubDeliveryId String             @unique
  eventType        String
  action           String?
  payload          Json
  status           WebhookEventStatus @default(RECEIVED)
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime           @default(now())

  @@map("webhook_events")
}

model RepositoryIndex {
  id                   String      @id @default(uuid())
  repositoryId         String      @unique
  status               IndexStatus @default(PENDING)
  lastIndexedCommitSha String?
  lastIndexedAt        DateTime?
  detectedFrameworks   String[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("repository_indexes")
}

model IndexingJob {
  id             String        @id @default(uuid())
  repositoryId   String
  trigger        SyncTrigger
  triggeredById  String?
  status         SyncJobStatus
  filesProcessed Int           @default(0)
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  errorMessage   String?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("indexing_jobs")
}

model RepositoryFile {
  id           String   @id @default(uuid())
  repositoryId String
  path         String
  language     String
  sizeBytes    Int
  linesOfCode  Int
  contentHash  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository          Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  symbols             CodeSymbol[]
  chunks              Chunk[]
  incomingImportEdges CodeGraphEdge[]

  @@unique([repositoryId, path])
  @@map("repository_files")
}

model CodeSymbol {
  id             String     @id @default(uuid())
  repositoryId   String
  fileId         String
  parentSymbolId String?
  kind           SymbolKind
  name           String
  signature      String?
  docComment     String?
  startLine      Int
  endLine        Int
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  repository    Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  file          RepositoryFile  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  parentSymbol  CodeSymbol?     @relation("SymbolHierarchy", fields: [parentSymbolId], references: [id], onDelete: Cascade)
  childSymbols  CodeSymbol[]    @relation("SymbolHierarchy")
  chunks        Chunk[]
  apiEndpoints  ApiEndpoint[]
  outgoingEdges CodeGraphEdge[] @relation("EdgeSource")
  incomingEdges CodeGraphEdge[] @relation("EdgeTarget")
  findings      Finding[]

  @@index([repositoryId, kind])
  @@map("code_symbols")
}

model Chunk {
  id              String          @id @default(uuid())
  repositoryId    String
  fileId          String
  symbolId        String?
  kind            ChunkKind
  content         String
  tokenCount      Int
  startLine       Int
  endLine         Int
  embeddingStatus EmbeddingStatus @default(PENDING)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  repository Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  file       RepositoryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  symbol     CodeSymbol?    @relation(fields: [symbolId], references: [id], onDelete: Cascade)
  citations  Citation[]

  @@index([repositoryId, embeddingStatus])
  @@map("chunks")
}

model CodeGraphEdge {
  id                String        @id @default(uuid())
  repositoryId      String
  sourceSymbolId    String
  targetSymbolId    String?
  targetPackageName String?
  targetFileId      String?
  edgeType          GraphEdgeType
  createdAt         DateTime      @default(now())

  repository   Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  sourceSymbol CodeSymbol      @relation("EdgeSource", fields: [sourceSymbolId], references: [id], onDelete: Cascade)
  targetSymbol CodeSymbol?     @relation("EdgeTarget", fields: [targetSymbolId], references: [id], onDelete: Cascade)
  targetFile   RepositoryFile? @relation(fields: [targetFileId], references: [id], onDelete: SetNull)

  @@index([repositoryId, edgeType])
  @@index([repositoryId, targetFileId])
  @@map("code_graph_edges")
}

model ApiEndpoint {
  id           String   @id @default(uuid())
  repositoryId String
  symbolId     String?
  filePath     String
  method       String
  path         String
  framework    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repository Repository  @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  symbol     CodeSymbol? @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([repositoryId, method])
  @@map("api_endpoints")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ToolInvocationStatus {
  SUCCESS
  FAILED
}

model Conversation {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  repositoryId   String?
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository   Repository?  @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@index([organizationId, userId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime    @default(now())

  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolInvocations ToolInvocation[]
  citations       Citation[]

  @@index([conversationId])
  @@map("messages")
}

model ToolInvocation {
  id               String               @id @default(uuid())
  messageId        String?
  agentExecutionId String?
  toolName         String
  arguments        Json
  result           Json?
  status           ToolInvocationStatus
  durationMs       Int?
  createdAt        DateTime             @default(now())

  message        Message?        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  agentExecution AgentExecution? @relation(fields: [agentExecutionId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([agentExecutionId])
  @@map("tool_invocations")
}

model Citation {
  id           String  @id @default(uuid())
  messageId    String
  chunkId      String?
  filePath     String
  repositoryId String

  message    Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunk      Chunk?     @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("citations")
}

enum AnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  RETRY
  CANCELLED
}

enum FindingCategory {
  QUALITY
  SECURITY
  PERFORMANCE
  ARCHITECTURE
  DEPENDENCY
  PATTERN
  SOLID
}

enum FindingSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model RepositoryAnalysis {
  id                   String         @id @default(uuid())
  repositoryId         String
  status               AnalysisStatus @default(PENDING)
  trigger              SyncTrigger
  triggeredById        String?
  commitSha            String?
  overallScore         Int?
  architectureScore    Int?
  securityScore        Int?
  performanceScore     Int?
  maintainabilityScore Int?
  scalabilityScore     Int?
  modularityScore      Int?
  layeringScore        Int?
  documentationScore   Int?
  complexityScore      Int?
  technicalDebtScore   Int?
  architectureSummary  String?
  retryCount           Int            @default(0)
  startedAt            DateTime       @default(now())
  completedAt          DateTime?
  errorMessage         String?
  // Machine-readable classification of errorMessage - see Task.errorCode.
  errorCode            String?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  findings   Finding[]

  @@index([repositoryId, startedAt])
  @@map("repository_analyses")
}

model Finding {
  id               String           @id @default(uuid())
  analysisId       String
  category         FindingCategory
  type             String
  severity         FindingSeverity
  priority         FindingSeverity?
  title            String
  explanation      String
  evidence         String?
  suggestedFix     String?
  estimatedImpact  String?
  confidence       Int
  filePath         String?
  startLine        Int?
  endLine          Int?
  symbolId         String?
  relatedFiles     String[]         @default([])
  relatedClasses   String[]         @default([])
  relatedFunctions String[]         @default([])
  metadata         Json?
  createdAt        DateTime         @default(now())

  analysis RepositoryAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  symbol   CodeSymbol?        @relation(fields: [symbolId], references: [id], onDelete: SetNull)

  @@index([analysisId, category])
  @@index([analysisId, severity])
  @@index([filePath])
  @@map("findings")
}

// --- Phase 6: AI Engineering Agent Platform ---

enum TaskStatus {
  QUEUED
  RUNNING
  PENDING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum MemoryScope {
  CONVERSATION
  TASK
  EXECUTION
}

model Task {
  id             String     @id @default(uuid())
  organizationId String
  repositoryId   String?
  createdById    String
  workflowKey    String?
  workflowParams Json?
  goal           String
  status         TaskStatus @default(QUEUED)
  progress       Int        @default(0)
  resultSummary  String?
  errorMessage   String?
  // Machine-readable classification of errorMessage (e.g. "rate_limited",
  // "not_configured" from ai-service's provider-error classifier) - lets the
  // client show a "go to profile settings" action for AI-provider issues
  // without fragile string-matching on errorMessage.
  errorCode      String?
  retryCount     Int        @default(0)

  // The resolved step graph this task is executing - stored once (either from
  // a code-defined workflow or the Planner agent) so a restart/retry resumes
  // the same plan instead of the Planner potentially generating a different one.
  planJson Json?

  // Write-tool approval gate: which step is waiting, who approved it, when.
  pendingStepId String?
  approvedById  String?
  approvedAt    DateTime?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repository   Repository?      @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  executions   AgentExecution[]
  incidents    Incident[]

  @@index([organizationId, status])
  @@index([repositoryId, startedAt])
  @@map("tasks")
}

model AgentExecution {
  id                String           @id @default(uuid())
  taskId            String
  agentKey          String
  stepIndex         Int
  parentExecutionId String?
  status            ExecutionStatus  @default(PENDING)
  input             Json
  output            Json?
  tokensUsed        Int?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())

  task            Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  logs            ExecutionLog[]
  validations     ValidationResult[]
  toolInvocations ToolInvocation[]

  @@index([taskId, stepIndex])
  @@map("agent_executions")
}

model ExecutionLog {
  id               String   @id @default(uuid())
  agentExecutionId String
  level            String
  message          String
  metadata         Json?
  createdAt        DateTime @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id], onDelete: Cascade)

  @@index([agentExecutionId, createdAt])
  @@map("execution_logs")
}

model ValidationResult {
  id               String   @id @default(uuid())
  agentExecutionId String
  passed           Boolean
  issues           Json?
  confidence       Int?
  createdAt        DateTime @default(now())

  agentExecution AgentExecution @relation(fields: [agentExecutionId], references: [id], onDelete: Cascade)

  @@index([agentExecutionId])
  @@map("validation_results")
}

model Memory {
  id        String      @id @default(uuid())
  scope     MemoryScope
  scopeId   String
  key       String
  value     Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([scope, scopeId, key])
  @@map("memories")
}

// --- Phase 7: Production Intelligence (AIOps) ---
//
// Raw logs/metrics/traces are never stored here - they stay in the source
// system (Prometheus, GitHub Actions, etc). This schema only stores: the
// dedup'd raw ingestion record (ProductionEvent, mirroring WebhookEvent),
// the deployment/service catalog, and the CORRELATED evidence and analysis
// output (IncidentSignal/RootCauseAnalysis/Recommendation/Postmortem) that
// the incident-analysis Task workflow produces - see
// modules/production/engine/ and modules/tasks/workflows/incidentAnalysis.workflow.ts.

enum ProductionProvider {
  PROMETHEUS
  GITHUB_ACTIONS
  // Future adapters (Grafana/Loki, OpenTelemetry, Jaeger, Kubernetes, Docker,
  // Datadog, New Relic, CloudWatch, Elastic, Jenkins) extend this enum and
  // implement the same MetricsAdapter/LogsAdapter/TracesAdapter/DeploymentAdapter/
  // ClusterAdapter interfaces - no changes needed to the correlation engine.
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum ServiceCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DeploymentStatus {
  SUCCESS
  FAILED
  ROLLED_BACK
  IN_PROGRESS
}

enum ProductionEventType {
  METRIC_ALERT
  DEPLOYMENT
}

enum ProductionEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum IncidentStatus {
  DETECTED
  INVESTIGATING
  ROOT_CAUSED
  RESOLVED
  CLOSED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentSignalType {
  DEPLOYMENT
  COMMIT
  PULL_REQUEST
  METRIC
  FINDING
  OWNERSHIP
}

enum RecommendationType {
  ROLLBACK
  CONFIG_CHANGE
  SCALING
  CACHING
  QUERY_OPTIMIZATION
  INFRA_OPTIMIZATION
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// An organization's connection to one external production system. `config`
// holds non-secret settings (base URL, etc); any credential is envelope-
// encrypted via infra/crypto/secretBox.ts before being written to
// encryptedCredential - never stored or logged in plaintext.
model ProductionIntegration {
  id                  String             @id @default(uuid())
  organizationId      String
  provider            ProductionProvider
  name                String
  config              Json
  encryptedCredential String?
  status              IntegrationStatus  @default(ACTIVE)
  createdById         String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services         Service[]
  productionEvents ProductionEvent[]

  @@index([organizationId, provider])
  @@map("production_integrations")
}

// Catalog of known deployables - the "which service/team owns this" anchor
// that deployments, incidents, and health snapshots hang off of.
model Service {
  id             String             @id @default(uuid())
  organizationId String
  integrationId  String?
  repositoryId   String?
  name           String
  ownerUserId    String?
  criticality    ServiceCriticality @default(MEDIUM)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration     ProductionIntegration?  @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  repository      Repository?             @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  deployments     Deployment[]
  incidents       Incident[]
  healthSnapshots ServiceHealthSnapshot[]

  @@unique([organizationId, name])
  @@map("services")
}

model Deployment {
  id             String             @id @default(uuid())
  organizationId String
  serviceId      String
  repositoryId   String?
  pullRequestId  String?
  commitSha      String?
  version        String?
  environment    String
  status         DeploymentStatus
  deployedAt     DateTime
  sourceProvider ProductionProvider
  sourceRunId    String?
  rawPayload     Json?
  createdAt      DateTime           @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  repository   Repository?  @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  pullRequest  PullRequest? @relation(fields: [pullRequestId], references: [id], onDelete: SetNull)
  incidents    Incident[]

  @@unique([serviceId, sourceProvider, sourceRunId])
  @@index([organizationId, serviceId, deployedAt])
  @@map("deployments")
}

// Raw ingestion record - dedup'd, persisted fast, processed async. Direct
// analog of WebhookEvent for non-GitHub production signals (Alertmanager
// alerts today; future push sources reuse the same table/queue).
model ProductionEvent {
  id             String                @id @default(uuid())
  organizationId String
  integrationId  String?
  eventType      ProductionEventType
  dedupeKey      String                @unique
  rawPayload     Json
  status         ProductionEventStatus @default(RECEIVED)
  processedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime              @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration  ProductionIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@map("production_events")
}

// The central incident record. `taskId` points at the *existing* Task engine
// run performing this incident's collect->correlate->analyze->recommend
// pipeline - see workflows/incidentAnalysis.workflow.ts - reusing
// AgentExecution/ExecutionLog/ValidationResult rather than a parallel engine.
model Incident {
  id              String           @id @default(uuid())
  organizationId  String
  serviceId       String?
  deploymentId    String?
  taskId          String?          @unique
  title           String
  status          IncidentStatus   @default(DETECTED)
  severity        IncidentSeverity
  detectedAt      DateTime         @default(now())
  resolvedAt      DateTime?
  confidenceScore Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service         Service?                @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  deployment      Deployment?             @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  task            Task?                   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  signals         IncidentSignal[]
  timeline        IncidentTimelineEvent[]
  rootCause       RootCauseAnalysis?
  recommendations Recommendation[]
  postmortem      Postmortem?

  @@index([organizationId, status])
  @@index([organizationId, detectedAt])
  @@map("incidents")
}

// The correlation engine's output - deterministic, scored evidence. The RCA
// step reasons ONLY over these rows, never raw logs/metrics, keeping token
// usage bounded and every claim traceable back to a concrete signal.
model IncidentSignal {
  id             String             @id @default(uuid())
  incidentId     String
  signalType     IncidentSignalType
  sourceRef      String?
  relevanceScore Int
  summary        String
  rawData        Json?
  createdAt      DateTime           @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, signalType])
  @@map("incident_signals")
}

model IncidentTimelineEvent {
  id          String   @id @default(uuid())
  incidentId  String
  occurredAt  DateTime
  eventType   String
  description String
  sourceRef   String?
  createdAt   DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, occurredAt])
  @@map("incident_timeline_events")
}

model RootCauseAnalysis {
  id                       String   @id @default(uuid())
  incidentId               String   @unique
  summary                  String
  mostLikelyCause          String
  confidenceScore          Int
  responsibleCommitSha     String?
  responsiblePullRequestId String?
  responsibleServiceId     String?
  responsibleUserId        String?
  rollbackRecommended      Boolean  @default(false)
  generatedAt              DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@map("root_cause_analyses")
}

model Recommendation {
  id              String                 @id @default(uuid())
  incidentId      String
  type            RecommendationType
  title           String
  description     String
  rationale       String
  priority        RecommendationPriority
  estimatedImpact String?
  confidenceScore Int
  createdAt       DateTime               @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("recommendations")
}

model Postmortem {
  id                  String    @id @default(uuid())
  incidentId          String    @unique
  organizationId       String
  executiveSummary    String
  timelineMarkdown    String
  rootCauseMarkdown   String
  contributingFactors String?
  customerImpact      String?
  recoverySteps       String?
  lessonsLearned      String?
  actionItems         Json?
  generatedAt         DateTime  @default(now())
  publishedAt         DateTime?

  incident     Incident     @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("postmortems")
}

model ServiceHealthSnapshot {
  id           String   @id @default(uuid())
  serviceId    String
  capturedAt   DateTime @default(now())
  errorRate    Float?
  p95LatencyMs Float?
  riskScore    Int?

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, capturedAt])
  @@map("service_health_snapshots")
}
