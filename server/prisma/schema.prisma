generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  DEVELOPER
  QA
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
  DECLINED
}

enum GitHubAccountType {
  USER
  ORGANIZATION
}

enum InstallationStatus {
  ACTIVE
  SUSPENDED
  UNINSTALLED
}

enum RepositoryVisibility {
  PUBLIC
  PRIVATE
  INTERNAL
}

enum SyncStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum SyncTrigger {
  MANUAL
  WEBHOOK
  SCHEDULED
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
}

enum IssueState {
  OPEN
  CLOSED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  clerkId      String   @unique
  name         String
  email        String   @unique
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships            OrganizationMember[]
  ownedOrgs              Organization[]       @relation("OrganizationOwner")
  sentInvites            Invitation[]         @relation("InvitationInviter")
  connectedInstallations GitHubInstallation[] @relation("InstallationConnectedBy")
  importedRepositories   Repository[]         @relation("RepositoryImportedBy")

  @@map("users")
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  logoUrl     String?
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  owner              User                 @relation("OrganizationOwner", fields: [ownerId], references: [id])
  members            OrganizationMember[]
  invitations        Invitation[]
  githubInstallation GitHubInstallation?
  repositories       Repository[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("organization_members")
}

model Invitation {
  id             String           @id @default(uuid())
  email          String
  organizationId String
  role           OrgRole
  invitedById    String
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitationInviter", fields: [invitedById], references: [id])

  @@unique([email, organizationId])
  @@map("invitations")
}

model GitHubInstallation {
  id                   String             @id @default(uuid())
  organizationId       String             @unique
  githubInstallationId BigInt             @unique
  githubAccountLogin   String
  githubAccountId      BigInt
  githubAccountType    GitHubAccountType
  status               InstallationStatus @default(ACTIVE)
  connectedById        String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  connectedBy  User         @relation("InstallationConnectedBy", fields: [connectedById], references: [id])
  repositories Repository[]

  @@map("github_installations")
}

model Repository {
  id              String               @id @default(uuid())
  organizationId  String
  installationId  String
  githubRepoId    BigInt
  name            String
  fullName        String
  ownerLogin      String
  description     String?
  visibility      RepositoryVisibility
  defaultBranch   String
  primaryLanguage String?
  topics          String[]
  cloneUrl        String
  htmlUrl         String
  starsCount      Int
  forksCount      Int
  openIssuesCount Int
  sizeKb          Int
  githubPushedAt  DateTime?
  githubCreatedAt DateTime
  githubUpdatedAt DateTime
  syncStatus      SyncStatus           @default(PENDING)
  lastSyncedAt    DateTime?
  importedById    String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  installation GitHubInstallation @relation(fields: [installationId], references: [id])
  importedBy   User               @relation("RepositoryImportedBy", fields: [importedById], references: [id])
  branches     Branch[]
  commits      Commit[]
  contributors Contributor[]
  pullRequests PullRequest[]
  issues       Issue[]
  syncs        RepositorySync[]

  @@unique([organizationId, githubRepoId])
  @@map("repositories")
}

model Branch {
  id            String    @id @default(uuid())
  repositoryId  String
  name          String
  isProtected   Boolean   @default(false)
  lastCommitSha String
  lastCommitAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, name])
  @@map("branches")
}

model Commit {
  id                String   @id @default(uuid())
  repositoryId      String
  sha               String
  message           String
  authorName        String
  authorEmail       String
  authorGithubLogin String?
  committedAt       DateTime
  htmlUrl           String
  createdAt         DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, sha])
  @@map("commits")
}

model Contributor {
  id            String   @id @default(uuid())
  repositoryId  String
  githubUserId  BigInt
  githubLogin   String
  avatarUrl     String?
  contributions Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, githubUserId])
  @@map("contributors")
}

model PullRequest {
  id              String           @id @default(uuid())
  repositoryId    String
  githubId        BigInt
  number          Int
  title           String
  state           PullRequestState
  authorLogin     String
  isDraft         Boolean          @default(false)
  sourceBranch    String
  targetBranch    String
  htmlUrl         String
  githubCreatedAt DateTime
  githubUpdatedAt DateTime
  mergedAt        DateTime?
  closedAt        DateTime?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, number])
  @@map("pull_requests")
}

model Issue {
  id              String     @id @default(uuid())
  repositoryId    String
  githubId        BigInt
  number          Int
  title           String
  state           IssueState
  authorLogin     String
  labels          String[]
  htmlUrl         String
  githubCreatedAt DateTime
  githubUpdatedAt DateTime
  closedAt        DateTime?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, number])
  @@map("issues")
}

model RepositorySync {
  id            String        @id @default(uuid())
  repositoryId  String
  trigger       SyncTrigger
  triggeredById String?
  status        SyncJobStatus
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  errorMessage  String?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("repository_syncs")
}

model WebhookEvent {
  id               String             @id @default(uuid())
  installationId   String?
  githubDeliveryId String             @unique
  eventType        String
  action           String?
  payload          Json
  status           WebhookEventStatus @default(RECEIVED)
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime           @default(now())

  @@map("webhook_events")
}
